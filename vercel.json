{
  "version": 2,
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/vercel" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/vercel.ts": {
      "maxDuration": 30
    }
  }
}
